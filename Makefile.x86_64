include common.mk

STATICPIE=-static-pie

COPTS += -D R_AMD64_RELATIVE=8 -Wl,-z,noseparate-code

lz4.x86_64.o: thirdparty/lz4/lz4.c thirdparty/lz4/lz4.h
	$(CC) \
	$(_COPTS) \
	-DLZ4_USER_MEMORY_FUNCTIONS \
	-c -o $@ $<

lz4.x86_64.elf.dbg: lz4.c lz4.x86_64.o $(HEADERS)
	$(CC) $(COPTS) \
	$(STATICPIE) \
	-o $@ $< lz4.x86_64.o

.SECONDARY:
%.x86_64.elf.dbg: %.c $(HEADERS)
	$(CC) $(COPTS) \
	$(STATICPIE) \
	-o $@ $<

%.x86_64.elf: %.x86_64.elf.dbg
	$(STRIP) $< -o $@

SYSTEM_ELFS = $(addsuffix .x86_64.elf,$(PROGS_SYSTEM))
SYSTEM_ELFS += $(addsuffix .x86_64.elf,$(PROGS_NET_SYSTEM))
USER_ELFS = $(addsuffix .x86_64.elf,$(PROGS_USER))
USER_ELFS += $(addsuffix .x86_64.elf,$(PROGS_NET_USER))

.PHONY: elfs
elfs: $(SYSTEM_ELFS) $(USER_ELFS) lz4.x86_64.elf

.PHONY: x86_64.tar
x86_64.tar: rootfs.tarwak.json elfs
	$(TARWAK) -i rootfs.tarwak.json -o $@ -b ./ -p "%s.x86_64.elf" $(_TARWAKFEATURES)

.PHONY: x86_64.erofs
x86_64.erofs: x86_64.tar
	$(EROFS_CMD) $@ $<

.PHONY: clean
clean:
	rm -f *.x86_64.elf *.x86_64.elf.dbg x86_64.tar x86_64.erofs

.PHONY: clang-tidy
clang-tidy:
	clang-tidy $(C_FILES) -- $(COPTS)
